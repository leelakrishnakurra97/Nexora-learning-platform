{
  "name": "eduverse-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "db:setup": "tsx scripts/setup-db.ts",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1069.0",
    "@aws-sdk/s3-request-presigner": "^3.1069.0",
    "@google/generative-ai": "^0.24.1",
    "@livekit/components-react": "^2.9.21",
    "@livekit/components-styles": "^1.2.0",
    "@prisma/client": "^6.19.3",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "livekit-client": "^2.19.2",
    "livekit-server-sdk": "^2.15.4",
    "lucide-react": "^0.547.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "embedded-postgres": "^17.5.0-beta.14",
    "pg": "^8.14.1",
    "postcss": "^8.4.36",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.19.3",
    "typescript": "^5.6.0",
    "vite": "^5.4.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
